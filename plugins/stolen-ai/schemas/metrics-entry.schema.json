{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Workflow Metrics Entry",
  "description": "One entry per workflow run, appended to metrics/metrics.jsonl",
  "type": "object",
  "required": ["timestamp", "workflow"],
  "properties": {
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of workflow completion"
    },
    "workflow": {
      "type": "string",
      "enum": ["po", "dev"],
      "description": "po = plan-feature pipeline, dev = plan-story pipeline"
    },
    "featureId": {
      "type": "integer",
      "description": "ADO Feature ID (PO workflow)"
    },
    "featureTitle": {
      "type": "string",
      "description": "Feature title (PO workflow)"
    },
    "storyId": {
      "type": "integer",
      "description": "ADO Story ID (Dev workflow)"
    },
    "storyTitle": {
      "type": "string",
      "description": "Story title (Dev workflow)"
    },
    "grillQuestions": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of grill questions asked before convergence"
    },
    "sliceRevisions": {
      "type": "integer",
      "minimum": 0,
      "description": "Feedback/revision rounds for slicing (PO workflow)"
    },
    "planRevisions": {
      "type": "integer",
      "minimum": 0,
      "description": "Feedback/revision rounds for plan (Dev workflow)"
    },
    "storiesProposed": {
      "type": "integer",
      "minimum": 0,
      "description": "Total stories in initial slice (PO workflow)"
    },
    "storiesAcceptedFirstPass": {
      "type": "integer",
      "minimum": 0,
      "description": "Stories accepted without any edits (PO workflow)"
    },
    "storiesEdited": {
      "type": "integer",
      "minimum": 0,
      "description": "Stories that needed human edits (PO workflow)"
    },
    "storiesRejected": {
      "type": "integer",
      "minimum": 0,
      "description": "Stories rejected entirely (PO workflow)"
    },
    "tasksPlanned": {
      "type": "integer",
      "minimum": 0,
      "description": "Tasks in plan breakdown (Dev workflow)"
    },
    "tasksCompletedFirstPass": {
      "type": "integer",
      "minimum": 0,
      "description": "Tasks completed without micro-review drift (Dev workflow)"
    },
    "microReviewDrifts": {
      "type": "integer",
      "minimum": 0,
      "description": "Times micro-review detected spec drift (Dev workflow)"
    },
    "escapedDefects": {
      "type": "integer",
      "minimum": 0,
      "description": "Issues discovered after workflow completed"
    },
    "notes": {
      "type": "string",
      "description": "Free-form observations or context"
    },
    "treatment": {
      "type": "string",
      "description": "Name of skill/agent change being tested. Omit for baseline runs. Used to filter treatment vs. baseline entries during lift-vs-drag comparison."
    },
    "durationMinutes": {
      "type": "number",
      "minimum": 0,
      "description": "Wall-clock time from workflow start (fetch) to completion (post/persist). Measures delivery performance and serves as human-time cost proxy."
    }
  },
  "allOf": [
    {
      "if": { "properties": { "workflow": { "const": "po" } } },
      "then": { "required": ["featureId", "grillQuestions", "sliceRevisions", "storiesProposed", "storiesAcceptedFirstPass"] }
    },
    {
      "if": { "properties": { "workflow": { "const": "dev" } } },
      "then": { "required": ["storyId", "grillQuestions", "planRevisions", "tasksPlanned", "tasksCompletedFirstPass"] }
    }
  ]
}
