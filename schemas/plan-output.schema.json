{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Dev Workflow - Plan Output",
  "description": "Contract between the Plan agent and the Persist script. Task breakdown with dependencies for a single Story.",
  "type": "object",
  "required": ["storyId", "storyTitle", "tasks", "decisions"],
  "properties": {
    "storyId": {
      "type": "string",
      "description": "ADO Story work item ID"
    },
    "storyTitle": {
      "type": "string"
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["decision", "rationale"],
        "properties": {
          "decision": { "type": "string" },
          "rationale": { "type": "string" }
        }
      },
      "description": "Key technical decisions made during dev grill"
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "description"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique task identifier (kebab-case)"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string",
            "description": "What to implement and how (2-4 hour scope)"
          },
          "testStrategy": {
            "type": "string",
            "description": "What to test and how"
          },
          "dependsOn": {
            "type": "array",
            "items": { "type": "string" },
            "description": "IDs of tasks that must complete first"
          }
        }
      }
    }
  }
}
